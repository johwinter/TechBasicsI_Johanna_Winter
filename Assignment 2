# Secret Number Game for Assignment 2
secret_number = 12

print("I'm thinking of a number. Can you guess it?")

guess = 0  # We set guess to 0 just to get the loop started

while guess != secret_number:

    guess = int(input("Your guess: "))  # int() converts the typed text into a number

    if guess < secret_number:
        print("Too low! Try again.")

    elif guess > secret_number:
        print("Too high! Try again.")

    else:
        print("Correct! Well done!")
